ENV=dev

# DB
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/selection_neuro

# CORS (front local)
CORS_ORIGINS=http://localhost:3000

# Admin (long & random)
ADMIN_TOKEN=CHANGE_ME_admin_very_long_random_token

# JWT
JWT_SECRET=CHANGE_ME_super_long_random_secret_64chars_min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe (dev/test)
STRIPE_SECRET_KEY=rk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# URLs de retour checkout (front local)
STRIPE_SUCCESS_URL=http://localhost:3000/checkout/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/cart

# Stripe mock pour tests locaux sans Stripe (true/false)
STRIPE_MOCK=false